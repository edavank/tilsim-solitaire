{
  "expo": {
    "name": "Tılsım Solitaire",
    "slug": "tilsim-solitaire",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "tilsim-solitaire",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#150629"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.edavank.tilsimsolitaire",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserTrackingUsageDescription": "Reklamları size özel hale getirmek için izninizi istiyoruz. İzin vermezseniz yine de uygulamamızı kullanabilirsiniz."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#150629"
      },
      "package": "com.edavank.tilsimsolitaire",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
